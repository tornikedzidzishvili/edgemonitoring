# API server
PORT=4000
DATABASE_URL="file:../../data/edge-monitoring.db"

# Used to encrypt SSH private keys stored in the database (AES-256-GCM).
# Keep this secret safe; rotating it requires re-encrypting stored keys.
SSH_KEY_MASTER_SECRET=change-me-change-me-change-me

# Uptime checker
CHECK_INTERVAL_SECONDS=60
CHECK_TIMEOUT_MS=10000
