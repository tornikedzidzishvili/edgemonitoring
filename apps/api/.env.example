# API server
PORT=4000
DATABASE_URL="file:../../data/edge-monitoring.db"

# Used to encrypt SSH private keys stored in the database (AES-256-GCM).
# Keep this secret safe; rotating it requires re-encrypting stored keys.
SSH_KEY_MASTER_SECRET=change-me-change-me-change-me

# Uptime checker
CHECK_INTERVAL_SECONDS=60
CHECK_TIMEOUT_MS=10000

# Public URL of this API, used as --api-url when the dashboard installs the
# agent on a remote server via SSH. The monitored server must be able to reach
# this URL from its network. Defaults to the production URL if unset.
# Change this in local/staging environments so the installed agent phones home
# to the right endpoint.
PUBLIC_API_URL=https://monitoring.edge.ge/api

# SSH polling cadence in milliseconds. Default 60000 = 60s.
# The startSshPollScheduler uses this to determine how often to poll
# servers with monitoringMode="ssh". Range: not enforced; values below
# 30000 will saturate the p-limit(5) concurrency cap on busy hosts.
SSH_POLL_INTERVAL_MS=60000
