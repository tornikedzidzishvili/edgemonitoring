generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Server {
  id           String   @id @default(cuid())
  name         String
  ip           String?
  vendor       String?
  specs        Json?
  sshUser      String?
  sshPort      Int?
  sshKeyId     String?
  sshKey       SshKey?  @relation(fields: [sshKeyId], references: [id])
  apiKeyHash   String?
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime?
  webApps      WebApp[]
  reports      ServerReport[]
  metricMinutes ServerMetricMinute[]
  alertConfig  ServerAlertConfig?
  alerts       ServerAlert[]

  @@index([apiKeyHash])
}

model ServerMetricMinute {
  id           String   @id @default(cuid())
  serverId     String
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  minuteStart  DateTime
  cpuLoadSum   Float    @default(0)
  memUsedPctSum Float   @default(0)
  samples      Int      @default(0)

  @@unique([serverId, minuteStart])
  @@index([minuteStart])
}

model SshKey {
  id             String   @id @default(cuid())
  name           String
  username       String?
  port           Int?
  privateKeyEnc  String
  privateKeyIv   String
  privateKeyTag  String
  passphraseEnc  String?
  passphraseIv   String?
  passphraseTag  String?
  createdAt      DateTime @default(now())
  servers        Server[]
}

model WebApp {
  id          String             @id @default(cuid())
  name        String
  url         String
  enabled     Boolean            @default(true)
  serverId    String?
  server      Server?            @relation(fields: [serverId], references: [id])
  createdAt   DateTime           @default(now())
  checks      UptimeCheckResult[]
}

model UptimeCheckResult {
  id             String   @id @default(cuid())
  webAppId       String
  webApp         WebApp   @relation(fields: [webAppId], references: [id], onDelete: Cascade)
  checkedAt      DateTime @default(now())
  ok             Boolean
  httpStatus     Int?
  responseTimeMs Int?
  error          String?

  @@index([webAppId, checkedAt])
  @@index([ok, checkedAt])
  @@index([checkedAt])
}

model ServerReport {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  reportedAt DateTime @default(now())
  payload    Json

  @@index([serverId, reportedAt])
  @@index([reportedAt])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  position     String?
  phone        String?
  role         String    @default("user") // "admin" or "user"
  
  // 2FA fields
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  passkeys     Passkey[]
  alertRecipient AlertRecipient?
  resolvedAlerts ServerAlert[]
}

model Passkey {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId      String   @unique
  publicKey         String
  counter           Int
  transports        String?  // JSON array of transport types
  name              String?  // User-friendly name for the passkey
  createdAt         DateTime @default(now())
  lastUsedAt        DateTime?

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model SmtpSettings {
  id          String   @id @default(cuid())
  host        String
  port        Int
  secure      Boolean  @default(true)
  username    String?
  passwordEnc String?
  passwordIv  String?
  passwordTag String?
  fromEmail   String
  fromName    String?
  updatedAt   DateTime @updatedAt
}

model SmsSettings {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(false)

  senderName String?

  apiKeyEnc String?
  apiKeyIv  String?
  apiKeyTag String?

  updatedAt DateTime @updatedAt
}

model AlertRecipient {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  email     String?
  phone     String?
  method    String   @default("none") // none | email | sms | both

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@index([method])
}

model AlertTemplate {
  id           String   @id @default(cuid())
  emailSubject String
  emailBody    String
  smsBody      String
  updatedAt    DateTime @updatedAt
}

// Shared Hosting Server Configuration (e.g., Plesk servers)
model SharedHostingServer {
  id             String   @id @default(cuid())
  name           String   // Label for this server (e.g., "Production Plesk", "Staging")
  type           String   @default("plesk") // "plesk" | "manual" (for future: cpanel, directadmin, etc.)
  apiUrl         String?  // Base URL for API (e.g., https://plesk.example.com:8443)
  
  // Encrypted API credentials
  apiKeyEnc      String?
  apiKeyIv       String?
  apiKeyTag      String?
  
  // Optional: username/password auth for some panels
  usernameEnc    String?
  usernameIv     String?
  usernameTag    String?
  passwordEnc    String?
  passwordIv     String?
  passwordTag    String?
  
  syncAll        Boolean  @default(true) // Sync all domains or only selected ones
  lastSyncAt     DateTime?
  lastSyncError  String?
  
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  accounts       SharedHosting[]
}

model SharedHosting {
  id        String   @id @default(cuid())
  name      String   // Customer/Account name
  
  // Link to hosting server (optional for backward compatibility)
  serverId  String?
  server    SharedHostingServer? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  
  // Plesk-specific identifiers
  pleskCustomerId String?
  pleskLogin      String?
  
  createdAt DateTime @default(now())
  domains   SharedHostingDomain[]
  
  @@index([serverId])
}

model SharedHostingDomain {
  id              String   @id @default(cuid())
  sharedHostingId String
  sharedHosting   SharedHosting @relation(fields: [sharedHostingId], references: [id], onDelete: Cascade)
  domain          String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())

  // Customer info from Plesk
  customerName    String?
  customerEmail   String?

  // SSL tracking
  sslExpiresAt    DateTime?
  sslIssuer       String?
  sslLastChecked  DateTime?

  // DNS tracking
  lastKnownIp     String?
  dnsLastChecked  DateTime?

  checks          DomainCheckResult[]

  @@unique([sharedHostingId, domain])
  @@index([sharedHostingId])
}

model DomainCheckResult {
  id              String   @id @default(cuid())
  domainId        String
  domain          SharedHostingDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  checkedAt       DateTime @default(now())

  // HTTP check
  httpOk          Boolean?
  httpStatus      Int?
  responseTimeMs  Int?
  httpError       String?

  // DNS check
  currentIp       String?
  ipChanged       Boolean  @default(false)

  @@index([domainId, checkedAt])
  @@index([checkedAt])
}

// Global alerting threshold settings (singleton)
model ServerAlertSettings {
  id                String   @id @default(cuid())
  cpuThresholdPct   Int      @default(90)
  cpuDurationMin    Int      @default(5)
  ramThresholdPct   Int      @default(90)
  ramDurationMin    Int      @default(5)
  offlineTimeoutMin Int      @default(3)
  updatedAt         DateTime @updatedAt
}

// Per-server alerting configuration
model ServerAlertConfig {
  id                String   @id @default(cuid())
  serverId          String   @unique
  server            Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  alertingEnabled   Boolean  @default(false)
  // Custom thresholds (null = use global)
  cpuThresholdPct   Int?
  cpuDurationMin    Int?
  ramThresholdPct   Int?
  ramDurationMin    Int?
  offlineTimeoutMin Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Active and historical alerts
model ServerAlert {
  id                String    @id @default(cuid())
  serverId          String
  server            Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type              String    // "cpu" | "ram" | "offline"
  thresholdValue    Float?
  actualValue       Float?
  status            String    @default("active") // "active" | "resolved"
  triggeredAt       DateTime  @default(now())
  resolvedAt        DateTime?
  resolvedById      String?
  resolvedBy        User?     @relation(fields: [resolvedById], references: [id])
  lastNotifiedAt    DateTime?
  notificationCount Int       @default(0)

  @@index([serverId, status])
  @@index([status, triggeredAt])
}
