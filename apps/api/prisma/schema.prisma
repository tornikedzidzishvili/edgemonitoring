generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Server {
  id           String   @id @default(cuid())
  name         String
  ip           String?
  vendor       String?
  specs        Json?
  sshUser      String?
  sshPort      Int?
  sshKeyId     String?
  sshKey       SshKey?  @relation(fields: [sshKeyId], references: [id])
  apiKeyHash   String?
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime?
  webApps      WebApp[]
  reports      ServerReport[]
  metricMinutes ServerMetricMinute[]
  alertConfig  ServerAlertConfig?
  alerts       ServerAlert[]
}

model ServerMetricMinute {
  id           String   @id @default(cuid())
  serverId     String
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  minuteStart  DateTime
  cpuLoadSum   Float    @default(0)
  memUsedPctSum Float   @default(0)
  samples      Int      @default(0)

  @@unique([serverId, minuteStart])
  @@index([serverId, minuteStart])
}

model SshKey {
  id             String   @id @default(cuid())
  name           String
  username       String?
  port           Int?
  privateKeyEnc  String
  privateKeyIv   String
  privateKeyTag  String
  passphraseEnc  String?
  passphraseIv   String?
  passphraseTag  String?
  createdAt      DateTime @default(now())
  servers        Server[]
}

model WebApp {
  id          String             @id @default(cuid())
  name        String
  url         String
  enabled     Boolean            @default(true)
  serverId    String?
  server      Server?            @relation(fields: [serverId], references: [id])
  createdAt   DateTime           @default(now())
  checks      UptimeCheckResult[]
}

model UptimeCheckResult {
  id             String   @id @default(cuid())
  webAppId       String
  webApp         WebApp   @relation(fields: [webAppId], references: [id])
  checkedAt      DateTime @default(now())
  ok             Boolean
  httpStatus     Int?
  responseTimeMs Int?
  error          String?

  @@index([webAppId, checkedAt])
}

model ServerReport {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id])
  reportedAt DateTime @default(now())
  payload    Json

  @@index([serverId, reportedAt])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  position     String?
  phone        String?
  role         String    @default("user") // "admin" or "user"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  alertRecipient AlertRecipient?
  resolvedAlerts ServerAlert[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model SmtpSettings {
  id        String   @id @default(cuid())
  host      String
  port      Int
  secure    Boolean  @default(true)
  username  String?
  password  String?  // encrypted
  fromEmail String
  fromName  String?
  updatedAt DateTime @updatedAt
}

model SmsSettings {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(false)

  senderName String?

  apiKeyEnc String?
  apiKeyIv  String?
  apiKeyTag String?

  updatedAt DateTime @updatedAt
}

model AlertRecipient {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  email     String?
  phone     String?
  method    String   @default("none") // none | email | sms | both

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@index([method])
}

model AlertTemplate {
  id           String   @id @default(cuid())
  emailSubject String
  emailBody    String
  smsBody      String
  updatedAt    DateTime @updatedAt
}

model SharedHosting {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  domains   SharedHostingDomain[]
}

model SharedHostingDomain {
  id              String   @id @default(cuid())
  sharedHostingId String
  sharedHosting   SharedHosting @relation(fields: [sharedHostingId], references: [id], onDelete: Cascade)
  domain          String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())

  // SSL tracking
  sslExpiresAt    DateTime?
  sslIssuer       String?
  sslLastChecked  DateTime?

  // DNS tracking
  lastKnownIp     String?
  dnsLastChecked  DateTime?

  checks          DomainCheckResult[]

  @@unique([sharedHostingId, domain])
  @@index([sharedHostingId])
}

model DomainCheckResult {
  id              String   @id @default(cuid())
  domainId        String
  domain          SharedHostingDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  checkedAt       DateTime @default(now())

  // HTTP check
  httpOk          Boolean?
  httpStatus      Int?
  responseTimeMs  Int?
  httpError       String?

  // DNS check
  currentIp       String?
  ipChanged       Boolean  @default(false)

  @@index([domainId, checkedAt])
}

// Global alerting threshold settings (singleton)
model ServerAlertSettings {
  id                String   @id @default(cuid())
  cpuThresholdPct   Int      @default(90)
  cpuDurationMin    Int      @default(5)
  ramThresholdPct   Int      @default(90)
  ramDurationMin    Int      @default(5)
  offlineTimeoutMin Int      @default(3)
  updatedAt         DateTime @updatedAt
}

// Per-server alerting configuration
model ServerAlertConfig {
  id                String   @id @default(cuid())
  serverId          String   @unique
  server            Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  alertingEnabled   Boolean  @default(false)
  // Custom thresholds (null = use global)
  cpuThresholdPct   Int?
  cpuDurationMin    Int?
  ramThresholdPct   Int?
  ramDurationMin    Int?
  offlineTimeoutMin Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Active and historical alerts
model ServerAlert {
  id                String    @id @default(cuid())
  serverId          String
  server            Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type              String    // "cpu" | "ram" | "offline"
  thresholdValue    Float?
  actualValue       Float?
  status            String    @default("active") // "active" | "resolved"
  triggeredAt       DateTime  @default(now())
  resolvedAt        DateTime?
  resolvedById      String?
  resolvedBy        User?     @relation(fields: [resolvedById], references: [id])
  lastNotifiedAt    DateTime?
  notificationCount Int       @default(0)

  @@index([serverId, status])
  @@index([status, triggeredAt])
}
