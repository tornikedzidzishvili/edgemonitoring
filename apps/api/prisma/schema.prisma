generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// How a server's metrics are collected.
// agent          — Dockerized agent pushes data (original path).
// agent_systemd  — Native systemd agent pushes data (no Docker required).
// ssh            — Platform polls the server over SSH (agentless).
// cyberpanel     — Platform reads inventory from a CyberPanel API (shared hosting).
enum MonitoringMode {
  agent
  agent_systemd
  ssh
  cyberpanel
}

// Which ingestion path produced a ServerReport row.
// agent — report was pushed by the Dockerized agent.
// ssh   — report was produced by the SSH polling scheduler.
enum ReportSource {
  agent
  ssh
}

model Server {
  id              String          @id @default(cuid())
  name            String
  ip              String?
  vendor          String?
  specs           Json?
  sshUser         String?
  sshPort         Int?
  sshKeyId        String?
  sshKey          SshKey?         @relation(fields: [sshKeyId], references: [id])
  apiKeyHash      String?
  monitoringMode  MonitoringMode  @default(agent)
  createdAt       DateTime        @default(now())
  lastSeenAt      DateTime?
  webApps         WebApp[]
  reports         ServerReport[]
  metricMinutes   ServerMetricMinute[]
  alertConfig     ServerAlertConfig?
  alerts          ServerAlert[]

  @@index([apiKeyHash])
}

model ServerMetricMinute {
  id           String   @id @default(cuid())
  serverId     String
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  minuteStart  DateTime
  cpuLoadSum   Float    @default(0)
  memUsedPctSum Float   @default(0)
  samples      Int      @default(0)

  @@unique([serverId, minuteStart])
  @@index([minuteStart])
}

model SshKey {
  id             String   @id @default(cuid())
  name           String
  username       String?
  port           Int?
  privateKeyEnc  String
  privateKeyIv   String
  privateKeyTag  String
  passphraseEnc  String?
  passphraseIv   String?
  passphraseTag  String?
  createdAt      DateTime @default(now())
  servers        Server[]
  sharedHostingServers SharedHostingServer[]
}

model WebApp {
  id          String             @id @default(cuid())
  name        String
  url         String
  enabled     Boolean            @default(true)
  serverId    String?
  server      Server?            @relation(fields: [serverId], references: [id])
  createdAt   DateTime           @default(now())
  checks      UptimeCheckResult[]
}

model UptimeCheckResult {
  id             String   @id @default(cuid())
  webAppId       String
  webApp         WebApp   @relation(fields: [webAppId], references: [id], onDelete: Cascade)
  checkedAt      DateTime @default(now())
  ok             Boolean
  httpStatus     Int?
  responseTimeMs Int?
  error          String?

  @@index([webAppId, checkedAt])
  @@index([ok, checkedAt])
  @@index([checkedAt])
}

model ServerReport {
  id         String       @id @default(cuid())
  serverId   String
  server     Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  reportedAt DateTime     @default(now())
  source     ReportSource @default(agent)
  payload    Json

  @@index([serverId, reportedAt])
  @@index([reportedAt])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  position     String?
  phone        String?
  role         String    @default("user") // "admin" or "user"
  
  // 2FA fields
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  passkeys     Passkey[]
  alertRecipient AlertRecipient?
  resolvedAlerts ServerAlert[]
}

model Passkey {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId      String   @unique
  publicKey         String
  counter           Int
  transports        String?  // JSON array of transport types
  name              String?  // User-friendly name for the passkey
  createdAt         DateTime @default(now())
  lastUsedAt        DateTime?

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model SmtpSettings {
  id          String   @id @default(cuid())
  host        String
  port        Int
  secure      Boolean  @default(true)
  username    String?
  passwordEnc String?
  passwordIv  String?
  passwordTag String?
  fromEmail   String
  fromName    String?
  updatedAt   DateTime @updatedAt
}

model SmsSettings {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(false)

  senderName String?

  apiKeyEnc String?
  apiKeyIv  String?
  apiKeyTag String?

  updatedAt DateTime @updatedAt
}

model AlertRecipient {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  email     String?
  phone     String?
  method    String   @default("none") // none | email | sms | both

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@index([method])
}

model AlertTemplate {
  id           String   @id @default(cuid())
  emailSubject String
  emailBody    String
  smsBody      String
  updatedAt    DateTime @updatedAt
}

// Shared Hosting Server Configuration (e.g., Plesk, CyberPanel servers)
model SharedHostingServer {
  id             String   @id @default(cuid())
  name           String   // Label for this server (e.g., "Production Plesk", "Staging")
  type           String   @default("plesk") // "plesk" | "manual" | "cyberpanel"
  apiUrl         String?  // Base URL for API (e.g., https://plesk.example.com:8443)

  // Encrypted API credentials
  apiKeyEnc      String?
  apiKeyIv       String?
  apiKeyTag      String?

  // Optional: username/password auth for some panels
  usernameEnc    String?
  usernameIv     String?
  usernameTag    String?
  passwordEnc    String?
  passwordIv     String?
  passwordTag    String?

  // SSH access — used by CyberPanel and other agentless polling types.
  // All fields are nullable so existing Plesk/manual rows are unaffected.
  sshHost        String?  // SSH host (IP or hostname); used by CyberPanel and any other agentless-SSH panel type
  sshKeyId       String?  // FK to SshKey; null for non-SSH panel types
  sshKey         SshKey?  @relation(fields: [sshKeyId], references: [id])
  sshUser        String?  // SSH login username (e.g., "root")
  sshPort        Int?     // SSH port; null means the service layer defaults to 22

  syncAll        Boolean  @default(true) // Sync all domains or only selected ones
  lastSyncAt     DateTime?
  lastSyncError  String?

  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts       SharedHosting[]
  alerts         SharedHostingAlert[]
}

// Alerts for CyberPanel service health (lscpd, lsws, mariadb).
// Sibling to ServerAlert — uses a FK to SharedHostingServer instead of Server
// because CyberPanel hosts are SharedHostingServer rows, not Server rows.
//
// status lifecycle:
//   "pending"  — service was inactive on cycle N; no notification sent yet.
//                Acts as the debounce buffer. Deleted on recovery before active.
//   "active"   — service was inactive on cycle N+1; notification has been sent.
//   "resolved" — service returned to active; resolution notification sent.
//
// This 2-cycle debounce prevents alert noise from brief service restarts
// (e.g., `systemctl restart lscpd`) that recover within one sync interval.
model SharedHostingAlert {
  id                String              @id @default(cuid())
  serverId          String
  server            SharedHostingServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type              String              // "lscpd" | "lsws" | "mariadb"
  status            String              @default("pending") // "pending" | "active" | "resolved"
  triggeredAt       DateTime            @default(now())
  resolvedAt        DateTime?
  lastNotifiedAt    DateTime?
  notificationCount Int                 @default(0)

  @@index([serverId, status])
  @@index([status, triggeredAt])
}

model SharedHosting {
  id        String   @id @default(cuid())
  name      String   // Customer/Account name
  
  // Link to hosting server (optional for backward compatibility)
  serverId  String?
  server    SharedHostingServer? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  
  // Plesk-specific identifiers
  pleskCustomerId String?
  pleskLogin      String?
  
  createdAt DateTime @default(now())
  domains   SharedHostingDomain[]
  
  @@index([serverId])
}

model SharedHostingDomain {
  id              String   @id @default(cuid())
  sharedHostingId String
  sharedHosting   SharedHosting @relation(fields: [sharedHostingId], references: [id], onDelete: Cascade)
  domain          String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())

  // Customer info from Plesk
  customerName    String?
  customerEmail   String?

  // SSL tracking
  sslExpiresAt    DateTime?
  sslIssuer       String?
  sslLastChecked  DateTime?

  // CyberPanel service status — JSON-encoded blob from CyberPanel polling.
  // Shape: { lscpd: "active"|"inactive", lsws: "active"|"inactive", mariadb: "active"|"inactive" }
  // Null for non-CyberPanel domains.
  serviceStatus   String?

  // DNS tracking
  lastKnownIp     String?
  dnsLastChecked  DateTime?

  checks          DomainCheckResult[]

  @@unique([sharedHostingId, domain])
  @@index([sharedHostingId])
}

model DomainCheckResult {
  id              String   @id @default(cuid())
  domainId        String
  domain          SharedHostingDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  checkedAt       DateTime @default(now())

  // HTTP check
  httpOk          Boolean?
  httpStatus      Int?
  responseTimeMs  Int?
  httpError       String?

  // DNS check
  currentIp       String?
  ipChanged       Boolean  @default(false)

  @@index([domainId, checkedAt])
  @@index([checkedAt])
}

// Container registry credentials used by the agent installer to pull the agent
// image on customer servers. Singleton — there is only ever one row.
//
// `tokenEnc/Iv/Tag` follow the cryptoBox AES-256-GCM pattern. The token is
// never stored or returned in plaintext; the API exposes only a `configured`
// boolean. Generic across registries (default ghcr.io, but works for Docker
// Hub, ECR, etc.).
model AgentInstallSettings {
  id          String   @id @default(cuid())
  registryUrl String   @default("ghcr.io")
  username    String?
  tokenEnc    String?
  tokenIv     String?
  tokenTag    String?
  updatedAt   DateTime @updatedAt
}

// Branding configuration (singleton — one row, created lazily on first write).
// Stores file-system paths to uploaded logo and favicon assets; binary files
// live on disk at /data/branding/. platformName drives the white-label display
// name shown across the dashboard and PWA manifest.
model BrandingSettings {
  id           String   @id @default(cuid())
  platformName String   @default("Edge Monitor")
  logoPath     String?
  logoMimeType String?
  faviconPath  String?
  faviconMime  String?
  updatedAt    DateTime @updatedAt
}

// Global alerting threshold settings (singleton)
model ServerAlertSettings {
  id                String   @id @default(cuid())
  cpuThresholdPct   Int      @default(90)
  cpuDurationMin    Int      @default(5)
  ramThresholdPct   Int      @default(90)
  ramDurationMin    Int      @default(5)
  offlineTimeoutMin Int      @default(3)
  updatedAt         DateTime @updatedAt
}

// Per-server alerting configuration
model ServerAlertConfig {
  id                String   @id @default(cuid())
  serverId          String   @unique
  server            Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  alertingEnabled   Boolean  @default(false)
  // Custom thresholds (null = use global)
  cpuThresholdPct   Int?
  cpuDurationMin    Int?
  ramThresholdPct   Int?
  ramDurationMin    Int?
  offlineTimeoutMin Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Active and historical alerts
model ServerAlert {
  id                String    @id @default(cuid())
  serverId          String
  server            Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type              String    // "cpu" | "ram" | "offline"
  thresholdValue    Float?
  actualValue       Float?
  status            String    @default("active") // "active" | "resolved"
  triggeredAt       DateTime  @default(now())
  resolvedAt        DateTime?
  resolvedById      String?
  resolvedBy        User?     @relation(fields: [resolvedById], references: [id])
  lastNotifiedAt    DateTime?
  notificationCount Int       @default(0)

  @@index([serverId, status])
  @@index([status, triggeredAt])
}
