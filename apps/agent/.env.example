# Central API URL
CENTRAL_API_URL=http://localhost:4000

# Server name shown in dashboard
SERVER_NAME=my-edge-server

# Agent key generated by the central API (/admin/servers)
AGENT_API_KEY=replace-me

# How often to report
REPORT_INTERVAL_SECONDS=30

# Docker socket (Linux default)
DOCKER_SOCKET_PATH=/var/run/docker.sock
